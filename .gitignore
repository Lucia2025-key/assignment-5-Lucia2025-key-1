# Results directory - generated by workflow
results/*
!results/report/
!results/report/phylogenetic_analysis_report.md
!results/alignment_stats/
!results/alignment_stats/summary_report.txt
!results/tree_comparison/
!results/tree_comparison/robinson_foulds_distances.txt/

# Data directory - input files
data/

# Snakemake hidden files
.snakemake/

# Log files
*.log
logs/

# Benchmark files
benchmarks/

# Temporary files
*.tmp
tmp/

# Mac OS
.DS_Store

# Python cache
__pycache__/
*.pyc
*.pyo

# R files
.Rhistory
.RData
.Rproj.user

# Large data files (consider adding specific patterns)
*.bam
*.sam
*.bai

# Conda environments (if built locally)
envs/**/
!envs/*.yaml

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/
